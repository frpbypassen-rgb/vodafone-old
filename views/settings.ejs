<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>إعدادات المنظومة | الأهرام</title>
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <style>
        .settings-nav { background: var(--input-bg); border-radius: 16px; padding: 10px; border: 1px solid var(--border-glass); margin-bottom: 25px; overflow-x: auto; white-space: nowrap;}
        .settings-nav .nav-link { color: var(--text-muted); font-weight: 700; border-radius: 12px; padding: 12px 20px; transition: 0.3s; margin: 0 4px; font-size: 0.9rem;}
        .settings-nav .nav-link:hover { background: var(--card-bg); color: var(--text-main); }
        .settings-nav .nav-link.active { background: var(--brand-primary); color: white !important; box-shadow: 0 4px 15px rgba(0, 26, 77, 0.2); }
        [data-theme="dark"] .settings-nav .nav-link.active { background: var(--brand-gold); color: black !important; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .min-w-fit { min-width: fit-content; }
        .mono-num { font-family: 'JetBrains Mono', monospace; font-size: 1.2rem;}
    </style>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'settings' }) %>

<div class="main-content">
    <div class="container-fluid">
        <div class="admin-nav mb-4">
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-gears text-primary me-2"></i> لوحة تحكم الإعدادات الشاملة</h3>
        </div>

        <ul class="nav nav-pills settings-nav d-flex flex-nowrap hide-scrollbar">
            <li class="nav-item text-center min-w-fit"><a class="nav-link active text-nowrap" href="/settings"><i class="fa-solid fa-sliders me-1"></i> العامة والأسعار</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/content"><i class="fa-solid fa-comment-dots me-1"></i> رسائل البوت</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/bots"><i class="fa-solid fa-robot me-1"></i> إدارة البوتات</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/excel"><i class="fa-solid fa-file-excel me-1"></i> محرر الإكسيل</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/clients-web"><i class="fa-solid fa-globe me-1"></i> ويب العملاء</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/executors-web"><i class="fa-solid fa-laptop-code me-1"></i> ويب المنفذين</a></li>
            <% if (typeof role !== 'undefined' && role === 'master') { %>
            <li class="nav-item text-center min-w-fit ms-auto"><a class="nav-link text-danger text-nowrap" href="/settings/users"><i class="fa-solid fa-user-shield me-1"></i> المديرين</a></li>
            <% } %>
        </ul>

        <div class="data-card p-4 border-start border-4 border-warning">
            <h5 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-money-bills text-warning me-2"></i> الإعدادات العامة للأسعار والمنظومة</h5>
            <form action="/settings/update" method="POST">
                <div class="row g-4">
                    <div class="col-md-12">
                        <div class="p-4 rounded-4 border" style="background-color: var(--input-bg);">
                            <h6 class="fw-bold mb-4 text-success"><i class="fa-solid fa-arrow-trend-up me-2"></i> مستويات أسعار الصرف</h6>
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-muted">سعر الصرف المستوى 1</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-end-0"><i class="fa-solid fa-coins text-muted"></i></span>
                                        <input type="number" step="any" name="rateLevel1" class="form-control fw-bold text-center text-primary mono-num border-start-0" value="<%= settings.rateLevel1 || 6.40 %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-muted">سعر الصرف المستوى 2</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-end-0"><i class="fa-solid fa-coins text-muted"></i></span>
                                        <input type="number" step="any" name="rateLevel2" class="form-control fw-bold text-center text-primary mono-num border-start-0" value="<%= settings.rateLevel2 || 6.45 %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-muted">سعر الصرف المستوى 3</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-end-0"><i class="fa-solid fa-coins text-muted"></i></span>
                                        <input type="number" step="any" name="rateLevel3" class="form-control fw-bold text-center text-primary mono-num border-start-0" value="<%= settings.rateLevel3 || 6.50 %>" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small"><i class="fa-solid fa-clock text-danger me-1"></i> توقيت الإغلاق التلقائي (التقفيل)</label>
                        <input type="time" name="closingTime" class="form-control text-center mono-num" value="<%= settings.closingTime || '23:59' %>" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small"><i class="fa-solid fa-headset text-info me-1"></i> حساب الدعم الفني (تليجرام)</label>
                        <input type="text" name="supportContact" class="form-control text-center mono-num" value="<%= settings.supportContact || '@AhramSupport' %>" dir="ltr" placeholder="@Username">
                    </div>

                    <div class="col-md-12 mt-4">
                        <div class="form-check form-switch p-4 rounded-4 d-flex align-items-center gap-3 border shadow-sm" style="background: <%= settings.isManualClosed ? 'rgba(239, 68, 68, 0.05)' : 'rgba(16, 185, 129, 0.05)' %>;">
                            <input class="form-check-input ms-0" type="checkbox" name="isManualClosed" value="true" id="manualClose" style="width: 3.5rem; height: 1.8rem; cursor: pointer;" <%= settings.isManualClosed ? 'checked' : '' %>>
                            <div class="ms-3">
                                <label class="form-check-label fw-bold fs-5 <%= settings.isManualClosed ? 'text-danger' : 'text-success' %>" for="manualClose" style="cursor: pointer;">تعليق وإغلاق النظام يدوياً للعملاء (صيانة/توقف)</label>
                                <div class="text-muted small mt-1">عند تفعيل هذا الخيار، لن يتمكن العملاء من تقديم طلبات تحويل جديدة حتى تقوم بإلغائه.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top text-end" style="border-color: var(--border-glass) !important;">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm rounded-pill"><i class="fa-solid fa-floppy-disk me-2"></i> حفظ الإعدادات</button>
                </div>
            </form>
        </div>
    </div>
</div>



<script>function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('active'); document.querySelector('.sidebar-overlay').classList.toggle('active'); }</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>